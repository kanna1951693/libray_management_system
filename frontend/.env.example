# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For Homebrew local: postgresql://your_mac_username@localhost:5432/library_db
# For password-protected: postgresql://postgres:yourpassword@localhost:5432/library_db
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/library_db"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (optional — for sending approval notifications) ────────────────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="City Library <your@gmail.com>"

# ─── Supabase Storage (for book cover image uploads) ─────────────────────────
# Create a project at https://supabase.com and copy credentials from:
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ─── Twilio WhatsApp (Optional — falls back to Mock Mode if empty) ────────────
# Sign up at https://www.twilio.com and enable the WhatsApp Sandbox:
#   Messaging → Try it out → Send a WhatsApp message
# Then copy credentials from: Console Dashboard → Account Info
#
# IMPORTANT: For Sandbox testing, use the Twilio sandbox number exactly as shown
# in your Twilio Console (e.g. +14155238886). Your recipients must also join the
# sandbox by sending the sandbox keyword to that number first.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token-here"
TWILIO_WHATSAPP_FROM="+14155238886"
